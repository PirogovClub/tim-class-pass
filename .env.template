# Multimodal YouTube Video Transcript Enrichment Pipeline Settings

# Per-step agents (overridden by pipeline.yml and by CLI)
# Options: ide (IDE as AI agent), openai, gemini
# The client implementation is chosen by these env vars:
# AGENT / AGENT_IMAGES / AGENT_DEDUP
AGENT_IMAGES=ide
AGENT_DEDUP=ide
# Fallback when step-specific not set:
AGENT=ide

# Project config: pipeline.yml in project root (default: agent_images, agent_dedup, batch_size)

# Model selection (for API agents)
# For OpenAI: gpt-4o, gpt-4-turbo, etc.
# For Gemini: default in code is gemini-2.5-flash-lite-preview-09-2025 (benchmark winner). Override below if needed.
MODEL_NAME=gpt-4o
# Optional step-specific models (fall back to MODEL_NAME): pipeline.yml overrides env when set.
# When agent=gemini, default is gemini-2.5-flash-lite-preview-09-2025 unless set here:
# MODEL_NAME=gemini-2.5-flash-lite-preview-09-2025
# MODEL_IMAGES=gemini-2.5-flash-lite-preview-09-2025
# MODEL_DEDUP=gemini-2.5-flash-lite-preview-09-2025
# Optional: GEMINI_STREAMING=1 to use streaming for dedup and gap detection (long prompts).

SSIM_THRESHOLD=0.95
TELEMETRY_ENABLED=1

# API Keys (required when using openai or gemini for any step)
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
