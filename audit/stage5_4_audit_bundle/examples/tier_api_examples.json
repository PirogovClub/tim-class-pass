      "is_promotable_to_gold": false,
      "resolved_at": "2026-03-24T12:00:00.000000+00:00",
      "policy_version": "tier_policy.v1"
    }
  },
  "get_tier_invalid_target_type": {
    "request": "GET /adjudication/tier?target_type=canonical_rule_family&target_id=fam-1",
    "response_400": {
      "error_code": "bad_request",
      "message": "Tiering not supported for target_type 'canonical_rule_family'",
      "details": {"target_type": "canonical_rule_family"}
    }
  },
