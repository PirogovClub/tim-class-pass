  "get_tier_success": {
    "request": "GET /adjudication/tier?target_type=rule_card&target_id=rule:w:1",
    "response_200": {
      "target_type": "rule_card",
      "target_id": "rule:w:1",
      "tier": "gold",
      "tier_reasons": [
        "Approved with no ambiguity, deferral, or unsupported flags."
      ],
      "blocker_codes": [],
      "is_eligible_for_downstream_use": true,
      "is_promotable_to_gold": false,
      "resolved_at": "2026-03-24T12:00:00.000000+00:00",
      "policy_version": "tier_policy.v1"
    }
  },
  "get_tier_unresolved_no_adjudication": {
    "request": "GET /adjudication/tier?target_type=rule_card&target_id=rule:http:1",
    "response_200": {
      "target_type": "rule_card",
      "target_id": "rule:http:1",
      "tier": "unresolved",
      "tier_reasons": ["No adjudication recorded for this rule card."],
      "blocker_codes": ["no_adjudication_state"],
