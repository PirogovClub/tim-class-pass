          "is_promotable_to_gold": false,
          "resolved_at": "2026-03-24T12:00:00.000000+00:00",
          "policy_version": "tier_policy.v1"
        }
      ],
      "total": 1
    }
  },
  "tiers_by_tier_silver_example": {
    "request": "GET /adjudication/tiers/by-tier?tier=silver&target_type=rule_card",
